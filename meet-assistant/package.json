{
  "name": "meet-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Invites a bot to a Google Meet, takes notes, emails the summary, and pushes your to-dos to TickTick.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "undici": "^6.20.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.5",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
